{
  "name": "@animated-resume/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json --noEmit false --outDir dist",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests=false",
    "lint": "tsc -p tsconfig.json --pretty false --noEmit",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/supertest": "^6.0.3",
    "supertest": "^7.1.1",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  }
}
